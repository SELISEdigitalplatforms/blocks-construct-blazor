@page "/forgot-password"
@rendermode InteractiveAuto
@layout AuthLayout
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Forgot Password</PageTitle>

<div class="flex flex-col gap-6">
    <div>
        <h1 class="text-2xl font-bold text-high-emphasis">Forgot Password?</h1>
        <p class="mt-1 text-sm font-normal text-medium-emphasis">Enter your registered email and we'll send you a reset link.</p>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">@_errorMessage</div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleSubmit" class="flex flex-col gap-4">
        <DataAnnotationsValidator />

        <div class="flex flex-col gap-1">
            <label class="text-sm font-normal text-high-emphasis">Email</label>
            <InputText @bind-Value="_model.Email"
                       class="w-full rounded-md border border-input px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                       placeholder="Enter your email" />
            <ValidationMessage For="@(() => _model.Email)" class="text-xs text-destructive" />
        </div>

        <button type="submit"
                class="mt-4 w-full rounded-md bg-primary py-2.5 text-sm font-extrabold text-white disabled:opacity-50 hover:bg-primary/90 transition-colors"
                disabled="@_isLoading">
            @(_isLoading ? "Sending..." : "Send Reset Link")
        </button>
    </EditForm>

    <a href="/login" class="block text-center text-sm font-bold text-primary hover:underline">Back to Login</a>
</div>

@code {
    private ForgotPasswordRequest _model = new();
    private string _errorMessage = "";
    private bool _isLoading;

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = "";

        try
        {
            await AuthService.ForgotPasswordAsync(_model.Email);
            Nav.NavigateTo("/email-sent");
        }
        catch
        {
            _errorMessage = "Something went wrong. Please try again or contact support.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
