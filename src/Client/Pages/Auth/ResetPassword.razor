@page "/reset-password"
@rendermode InteractiveAuto
@layout AuthLayout
@inject IAuthService AuthService

<PageTitle>Reset Password</PageTitle>

<div class="flex flex-col gap-6">
    <div>
        <h1 class="text-2xl font-bold text-high-emphasis">Reset Password</h1>
        <p class="mt-1 text-sm text-medium-emphasis">Enter your new password below.</p>
    </div>

    @if (_isSuccess)
    {
        <div class="rounded-lg border border-green-200 bg-green-50 p-4 text-sm text-green-700">
            <strong>Password reset successfully!</strong>
            <a href="/login" class="ml-1 font-bold underline">Click here to log in.</a>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">@_errorMessage</div>
    }

    @if (!_isSuccess)
    {
        <EditForm Model="_model" OnValidSubmit="HandleSubmit" class="flex flex-col gap-4">
            <DataAnnotationsValidator />

            <div class="flex flex-col gap-1">
                <label class="text-sm font-normal text-high-emphasis">New Password</label>
                <PasswordInput @bind-Value="_model.Password" Placeholder="Enter new password" />
                <ValidationMessage For="@(() => _model.Password)" class="text-xs text-destructive" />
                <PasswordStrengthBar Password="@_model.Password" />
            </div>

            <div class="flex flex-col gap-1">
                <label class="text-sm font-normal text-high-emphasis">Confirm Password</label>
                <PasswordInput @bind-Value="_model.ConfirmPassword" Placeholder="Confirm new password" />
                <ValidationMessage For="@(() => _model.ConfirmPassword)" class="text-xs text-destructive" />
            </div>

            <button type="submit"
                    class="mt-4 w-full rounded-md bg-primary py-2.5 text-sm font-extrabold text-white disabled:opacity-50 hover:bg-primary/90 transition-colors"
                    disabled="@_isLoading">
                @(_isLoading ? "Resetting..." : "Reset Password")
            </button>
        </EditForm>
    }

    <a href="/login" class="text-center text-sm font-bold text-primary hover:underline">Back to Login</a>
</div>

@code {
    private ResetPasswordRequest _model = new();
    private string _errorMessage = "";
    private bool _isLoading;
    private bool _isSuccess;

    [SupplyParameterFromQuery(Name = "code")]
    private string Code { get; set; } = "";

    protected override void OnParametersSet()
    {
        _model.Code = Code;
    }

    private async Task HandleSubmit()
    {
        _isLoading = true;
        _errorMessage = "";

        try
        {
            await AuthService.ResetPasswordAsync(_model);
            _isSuccess = true;
        }
        catch
        {
            _errorMessage = "Failed to reset password. The link may have expired - please request a new one.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
