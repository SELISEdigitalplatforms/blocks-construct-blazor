@page "/login"
@rendermode InteractiveAuto
@layout AuthLayout
@inject IAuthService AuthService
@inject AppAuthStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Log In</PageTitle>

<div class="flex flex-col gap-6">
    <div>
        <h1 class="text-2xl font-bold text-high-emphasis">Log In</h1>
        <div class="mt-1 flex items-center gap-1">
            <span class="text-sm font-normal text-medium-emphasis">Don't have an account?</span>
            <a href="/signup" class="text-sm font-bold text-primary hover:underline">Sign Up</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700" role="alert">
            <strong>Invalid credentials.</strong> @_errorMessage
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="HandleLogin" class="flex flex-col gap-4">
        <DataAnnotationsValidator />

        <div class="flex flex-col gap-1">
            <label class="text-sm font-normal text-high-emphasis">Email</label>
            <InputText @bind-Value="_model.Username"
                       class="w-full rounded-md border border-input px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
                       placeholder="Enter your email" />
            <ValidationMessage For="@(() => _model.Username)" class="text-xs text-destructive" />
        </div>

        <div class="flex flex-col gap-1">
            <label class="text-sm font-normal text-high-emphasis">Password</label>
            <PasswordInput @bind-Value="_model.Password" Placeholder="Enter your password" />
            <ValidationMessage For="@(() => _model.Password)" class="text-xs text-destructive" />
        </div>

        <div class="flex justify-end">
            <a href="/forgot-password" class="text-sm text-primary hover:text-primary-600 hover:underline">
                Forgot Password?
            </a>
        </div>

        <button type="submit"
                class="w-full rounded-md bg-primary py-2.5 text-sm font-extrabold text-white disabled:opacity-50 hover:bg-primary/90 transition-colors"
                disabled="@_isLoading">
            @(_isLoading ? "Logging in..." : "Log In")
        </button>
    </EditForm>
</div>

@code {
    private SignInRequest _model = new();
    private string _errorMessage = "";
    private bool _isLoading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var token = await AuthService.GetAccessTokenAsync();
        if (!string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/dashboard", replace: true);
        }
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = "";

        try
        {
            var result = await AuthService.SignInAsync(_model.Username, _model.Password);

            if (result.EnableMfa)
            {
                Nav.NavigateTo($"/verify-mfa?mfa_id={result.MfaId}&mfa_type={result.MfaType}&user_name={Uri.EscapeDataString(_model.Username)}", replace: true);
                return;
            }

            AuthState.NotifyAuthStateChanged();
            Nav.NavigateTo("/dashboard", replace: true);
        }
        catch
        {
            _errorMessage = "Your email or password is incorrect. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
