@page "/"
@rendermode InteractiveAuto

<PageTitle>Home — Blocks Platform</PageTitle>

<div class="min-h-screen bg-white">

    @* ───── Navigation ───── *@
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded-lg bg-linear-to-br from-teal-500 to-cyan-600 flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    </div>
                    <span class="text-xl font-bold text-gray-900 tracking-tight">Blocks</span>
                </div>
                <div class="hidden md:flex items-center gap-8">
                    <a href="#features" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Features</a>
                    <a href="#stats" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Results</a>
                    <a href="#testimonials" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Testimonials</a>
                    <a href="#pricing" class="text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors">Pricing</a>
                </div>
                <div class="flex items-center gap-3">
                    <a href="/auth/login" class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">Sign in</a>
                    <a href="/auth/login" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-white bg-linear-to-r from-teal-500 to-cyan-600 rounded-lg shadow-sm hover:from-teal-600 hover:to-cyan-700 transition-all duration-200 hover:shadow-md">
                        Get Started
                    </a>
                </div>
            </div>
        </div>
    </nav>

    @* ───── Hero Section ───── *@
    <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden">
        <div class="absolute inset-0 bg-linear-to-br from-teal-50 via-white to-cyan-50"></div>
        <div class="absolute top-20 left-1/4 w-96 h-96 bg-teal-200/30 rounded-full blur-3xl"></div>
        <div class="absolute bottom-10 right-1/4 w-80 h-80 bg-cyan-200/20 rounded-full blur-3xl"></div>

        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-4xl mx-auto">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-teal-50 border border-teal-200 rounded-full text-sm font-medium text-teal-700 mb-8">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
                    </span>
                    Now available — Enterprise Platform v3.0
                </div>

                <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-gray-900 tracking-tight leading-[1.1]">
                    Build faster with
                    <span class="bg-linear-to-r from-teal-500 to-cyan-600 bg-clip-text text-transparent">enterprise-grade</span>
                    infrastructure
                </h1>

                <p class="mt-8 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
                    Accelerate development with secure identity, data management, AI services, and real-time communication — all in one unified platform.
                </p>

                <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
                    <a href="/auth/login" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-linear-to-r from-teal-500 to-cyan-600 rounded-xl shadow-lg shadow-teal-500/25 hover:shadow-xl hover:shadow-teal-500/30 hover:from-teal-600 hover:to-cyan-700 transition-all duration-300">
                        Start building for free
                        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                        </svg>
                    </a>
                    <a href="#features" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 hover:border-gray-300 transition-all duration-200">
                        <svg class="mr-2 w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Watch demo
                    </a>
                </div>

                <div class="mt-12 flex items-center justify-center gap-8 text-sm text-gray-500">
                    <div class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        No credit card required
                    </div>
                    <div class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        14-day free trial
                    </div>
                    <div class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                        SOC 2 compliant
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ───── Trusted By / Logo Cloud ───── *@
    <section class="py-16 bg-gray-50/50 border-y border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <p class="text-center text-sm font-medium text-gray-400 uppercase tracking-widest mb-10">Trusted by innovative teams worldwide</p>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-8 items-center justify-items-center opacity-50">
                @foreach (var company in _trustedCompanies)
                {
                    <div class="text-gray-400 font-bold text-lg tracking-wide">@company</div>
                }
            </div>
        </div>
    </section>

    @* ───── Features Grid ───── *@
    <section id="features" class="py-24 lg:py-32">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-20">
                <p class="text-sm font-semibold text-teal-600 uppercase tracking-widest mb-3">Capabilities</p>
                <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 tracking-tight">
                    Everything you need to ship faster
                </h2>
                <p class="mt-5 text-lg text-gray-600">
                    A complete platform that handles the complexity so your team can focus on building what matters.
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var feature in _features)
                {
                    <div class="group relative p-8 bg-white rounded-2xl border border-gray-100 hover:border-teal-200 hover:shadow-xl hover:shadow-teal-500/5 transition-all duration-300">
                        <div class="w-12 h-12 rounded-xl bg-linear-to-br @feature.GradientClasses flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                            @((MarkupString)feature.Icon)
                        </div>
                        <h3 class="text-xl font-semibold text-gray-900 mb-3">@feature.Title</h3>
                        <p class="text-gray-600 leading-relaxed">@feature.Description</p>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ───── Stats Section ───── *@
    <section id="stats" class="py-24 bg-linear-to-br from-gray-900 via-gray-800 to-gray-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <p class="text-sm font-semibold text-teal-400 uppercase tracking-widest mb-3">By the numbers</p>
                <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
                    Trusted by thousands of developers
                </h2>
            </div>

            <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach (var stat in _stats)
                {
                    <div class="text-center p-8 rounded-2xl bg-white/5 border border-white/10 backdrop-blur-sm">
                        <div class="text-4xl sm:text-5xl font-extrabold bg-linear-to-r from-teal-400 to-cyan-400 bg-clip-text text-transparent">
                            @stat.Value
                        </div>
                        <div class="mt-2 text-sm font-medium text-gray-400">@stat.Label</div>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ───── Feature Highlight ───── *@
    <section class="py-24 lg:py-32">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div>
                    <p class="text-sm font-semibold text-teal-600 uppercase tracking-widest mb-3">Developer Experience</p>
                    <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">
                        Ship features, not infrastructure
                    </h2>
                    <p class="mt-5 text-lg text-gray-600 leading-relaxed">
                        Stop re-building auth, data layers, and notification systems. Blocks provides production-ready services out of the box so you can focus on your unique business logic.
                    </p>
                    <ul class="mt-8 space-y-4">
                        @foreach (var item in _highlightItems)
                        {
                            <li class="flex items-start gap-3">
                                <div class="shrink-0 w-6 h-6 rounded-full bg-teal-100 flex items-center justify-center mt-0.5">
                                    <svg class="w-4 h-4 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                </div>
                                <span class="text-gray-700">@item</span>
                            </li>
                        }
                    </ul>
                </div>
                <div class="relative">
                    <div class="absolute inset-0 bg-linear-to-br from-teal-100 to-cyan-100 rounded-3xl transform rotate-3"></div>
                    <div class="relative bg-gray-900 rounded-2xl p-6 shadow-2xl">
                        <div class="flex items-center gap-2 mb-4">
                            <div class="w-3 h-3 rounded-full bg-red-400"></div>
                            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                            <div class="w-3 h-3 rounded-full bg-green-400"></div>
                        </div>
                        <pre class="text-sm text-gray-300 font-mono overflow-x-auto"><code><span class="text-teal-400">@@inject</span> IBlocksClient Blocks

<span class="text-gray-500">// Query data with GraphQL</span>
<span class="text-cyan-400">var</span> result = <span class="text-cyan-400">await</span> Blocks.Data
    .Query(<span class="text-amber-300">"products"</span>)
    .Select(<span class="text-amber-300">"name"</span>, <span class="text-amber-300">"price"</span>)
    .Where(p => p.Price > <span class="text-purple-400">100</span>)
    .ExecuteAsync();

<span class="text-gray-500">// Send notification</span>
<span class="text-cyan-400">await</span> Blocks.Notify
    .Send(<span class="text-amber-300">"order-confirmed"</span>, user);</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ───── Testimonials ───── *@
    <section id="testimonials" class="py-24 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <p class="text-sm font-semibold text-teal-600 uppercase tracking-widest mb-3">Testimonials</p>
                <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">
                    Loved by engineering teams
                </h2>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                @foreach (var testimonial in _testimonials)
                {
                    <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow duration-300">
                        <div class="flex items-center gap-1 mb-4">
                            @for (int i = 0; i < 5; i++)
                            {
                                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            }
                        </div>
                        <p class="text-gray-700 leading-relaxed mb-6">"@testimonial.Quote"</p>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-linear-to-br from-teal-400 to-cyan-500 flex items-center justify-center text-white font-semibold text-sm">
                                @testimonial.Initials
                            </div>
                            <div>
                                <div class="font-semibold text-gray-900 text-sm">@testimonial.Name</div>
                                <div class="text-gray-500 text-sm">@testimonial.Role</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ───── Pricing Preview ───── *@
    <section id="pricing" class="py-24 lg:py-32">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <p class="text-sm font-semibold text-teal-600 uppercase tracking-widest mb-3">Pricing</p>
                <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 tracking-tight">
                    Simple, transparent pricing
                </h2>
                <p class="mt-5 text-lg text-gray-600">Start free. Scale as you grow.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
                @foreach (var plan in _plans)
                {
                    <div class="relative p-8 bg-white rounded-2xl border @(plan.IsPopular ? "border-teal-300 shadow-xl shadow-teal-500/10 ring-1 ring-teal-200" : "border-gray-200") transition-shadow duration-300">
                        @if (plan.IsPopular)
                        {
                            <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-linear-to-r from-teal-500 to-cyan-600 text-white text-xs font-semibold rounded-full shadow-lg">
                                Most Popular
                            </div>
                        }
                        <h3 class="text-lg font-semibold text-gray-900">@plan.Name</h3>
                        <div class="mt-4 flex items-baseline gap-1">
                            <span class="text-4xl font-extrabold text-gray-900">@plan.Price</span>
                            @if (!string.IsNullOrEmpty(plan.Period))
                            {
                                <span class="text-gray-500 text-sm">@plan.Period</span>
                            }
                        </div>
                        <p class="mt-3 text-sm text-gray-500">@plan.Description</p>
                        <ul class="mt-8 space-y-3">
                            @foreach (var item in plan.Features)
                            {
                                <li class="flex items-center gap-2 text-sm text-gray-700">
                                    <svg class="w-4 h-4 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                    @item
                                </li>
                            }
                        </ul>
                        <a href="/auth/login"
                           class="mt-8 block w-full text-center px-6 py-3 text-sm font-semibold rounded-xl transition-all duration-200 @(plan.IsPopular ? "text-white bg-linear-to-r from-teal-500 to-cyan-600 hover:from-teal-600 hover:to-cyan-700 shadow-lg shadow-teal-500/25" : "text-gray-700 bg-gray-50 border border-gray-200 hover:bg-gray-100")">
                            @plan.ButtonText
                        </a>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ───── CTA Section ───── *@
    <section class="py-24 bg-linear-to-br from-teal-600 via-teal-700 to-cyan-800">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white tracking-tight">
                Ready to accelerate your development?
            </h2>
            <p class="mt-6 text-lg text-teal-100 max-w-2xl mx-auto">
                Join thousands of teams building production applications on Blocks. Get started in minutes, not months.
            </p>
            <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
                <a href="/auth/login" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-teal-700 bg-white rounded-xl shadow-lg hover:bg-teal-50 transition-all duration-200">
                    Start building today
                    <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                </a>
                <a href="#features" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white border border-white/30 rounded-xl hover:bg-white/10 transition-all duration-200">
                    Talk to sales
                </a>
            </div>
        </div>
    </section>

    @* ───── Footer ───── *@
    <footer class="bg-gray-900 py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
                <div>
                    <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Product</h4>
                    <ul class="space-y-3">
                        <li><a href="#features" class="text-sm text-gray-400 hover:text-white transition-colors">Features</a></li>
                        <li><a href="#pricing" class="text-sm text-gray-400 hover:text-white transition-colors">Pricing</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Changelog</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Documentation</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Platform</h4>
                    <ul class="space-y-3">
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Identity &amp; Access</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Data Management</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">AI Services</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Communication</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Company</h4>
                    <ul class="space-y-3">
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">About</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Blog</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Careers</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Contact</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Legal</h4>
                    <ul class="space-y-3">
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Privacy</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Terms</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">Security</a></li>
                        <li><a href="#" class="text-sm text-gray-400 hover:text-white transition-colors">GDPR</a></li>
                    </ul>
                </div>
            </div>
            <div class="pt-8 border-t border-gray-800 flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-lg bg-linear-to-br from-teal-500 to-cyan-600 flex items-center justify-center">
                        <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                    </div>
                    <span class="text-sm text-gray-400">&copy; @DateTime.Now.Year Blocks Platform. All rights reserved.</span>
                </div>
