@inject IJSRuntime JS

<div class="flex items-center gap-0.5 rounded-lg bg-gray-100 dark:bg-gray-800 p-1" title="Switch theme">

    @* Light *@
    <button @onclick='() => SetTheme("light")'
            class="@Cls("light") rounded-md p-1.5 transition-colors"
            title="Light">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z" />
        </svg>
    </button>

    @* Dark *@
    <button @onclick='() => SetTheme("dark")'
            class="@Cls("dark") rounded-md p-1.5 transition-colors"
            title="Dark">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M20.354 15.354A9 9 0 0 1 8.646 3.646 9.003 9.003 0 0 0 12 21a9.003 9.003 0 0 0 8.354-5.646z" />
        </svg>
    </button>

    @* System *@
    <button @onclick='() => SetTheme("system")'
            class="@Cls("system") rounded-md p-1.5 transition-colors"
            title="System">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M9.75 17 9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z" />
        </svg>
    </button>

</div>

@code {
    private string _current = "system";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _current = await JS.InvokeAsync<string?>("themeManager.get") ?? "system";
            StateHasChanged();
        }
    }

    private async Task SetTheme(string theme)
    {
        _current = theme;
        await JS.InvokeVoidAsync("themeManager.set", theme);
    }

    private string Cls(string theme) => _current == theme
        ? "bg-white dark:bg-gray-700 text-primary-600 dark:text-primary-400 shadow-sm"
        : "text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200";
}
