@inject SidebarState Sidebar

<header class="flex h-14 shrink-0 items-center justify-between border-b bg-card px-4 lg:px-6">
    <div class="flex items-center gap-3">
        <button @onclick="Sidebar.ToggleMobile" class="rounded p-1 text-medium-emphasis hover:bg-muted lg:hidden">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>

        <DynamicBreadcrumb />
    </div>

    <div class="flex items-center gap-2">
        <button class="relative rounded-full p-2 text-medium-emphasis hover:bg-muted">@((MarkupString)Icons.Bell)</button>
        <ProfileMenu />
    </div>
</header>
