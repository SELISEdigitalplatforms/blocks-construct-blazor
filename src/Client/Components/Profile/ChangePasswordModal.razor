<div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="w-full max-w-sm rounded-xl bg-card p-6 shadow-xl">
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-lg font-bold text-high-emphasis">Change Password</h2>
            <button @onclick="OnClose" class="text-medium-emphasis hover:text-high-emphasis">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        @if (_success)
        {
            <div class="mb-3 rounded border border-green-200 bg-green-50 p-3 text-sm text-green-700">Password changed successfully.</div>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="mb-3 rounded border border-red-200 bg-red-50 p-3 text-sm text-red-700">@_error</div>
        }

        @if (!_success)
        {
            <EditForm Model="_form" OnValidSubmit="HandleSave" class="flex flex-col gap-4">
                <DataAnnotationsValidator />

                <FormField Label="Current Password" Required="true">
                    <PasswordInput @bind-Value="_form.CurrentPassword" Placeholder="Current password" />
                </FormField>

                <FormField Label="New Password" Required="true">
                    <PasswordInput @bind-Value="_form.NewPassword" Placeholder="New password" />
                    <PasswordStrengthBar Password="@_form.NewPassword" />
                </FormField>

                <FormField Label="Confirm Password" Required="true">
                    <PasswordInput @bind-Value="_form.ConfirmPassword" Placeholder="Confirm password" />
                </FormField>

                <div class="mt-2 flex justify-end gap-3">
                    <button type="button" @onclick="OnClose" class="rounded-md border border-border px-4 py-2 text-sm hover:bg-muted">Cancel</button>
                    <button type="submit" class="rounded-md bg-primary px-4 py-2 text-sm font-extrabold text-white hover:bg-primary/90 disabled:opacity-50" disabled="@_saving">@(_saving ? "Saving..." : "Save")</button>
                </div>
            </EditForm>
        }
        else
        {
            <button @onclick="OnClose" class="mt-2 w-full rounded-md bg-primary px-4 py-2 text-sm font-extrabold text-white hover:bg-primary/90">Close</button>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Inject] private IUserService UserService { get; set; } = default!;

    private ChangePasswordForm _form = new();
    private string _error = "";
    private bool _saving;
    private bool _success;

    private async Task HandleSave()
    {
        _saving = true;
        _error = "";
        try
        {
            await UserService.ChangePasswordAsync(_form.CurrentPassword, _form.NewPassword);
            _success = true;
        }
        catch
        {
            _error = "Failed to change password. Please try again.";
        }
        finally
        {
            _saving = false;
        }
    }

    public class ChangePasswordForm
    {
        [Required] public string CurrentPassword { get; set; } = "";
        [Required] public string NewPassword { get; set; } = "";
        [Required, Compare(nameof(NewPassword))] public string ConfirmPassword { get; set; } = "";
    }
}
