@inherits LayoutComponentBase
@inject SidebarState Sidebar
@implements IDisposable

<ErrorBoundary>
    <ChildContent>
        <AuthorizeView>
            <Authorized>
                <div class="flex h-screen overflow-hidden bg-background">
                    <AppSidebar />

                    @if (Sidebar.IsMobileOpen)
                    {
                        <div class="fixed inset-0 z-20 bg-black/50 lg:hidden" @onclick="Sidebar.CloseMobile"></div>
                    }

                    <div class="flex min-w-0 flex-1 flex-col overflow-hidden">
                        <TopNavBar />

                        <main class="flex-1 overflow-y-auto p-4 md:p-6">
                            @Body
                        </main>
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeView>
    </ChildContent>
    <ErrorContent>
        <div class="flex items-center gap-3 rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700" role="alert">
            <svg class="h-5 w-5 shrink-0 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
            </svg>
            <span>An error has occurred. <a href="." class="font-semibold underline hover:no-underline">Reload</a></span>
        </div>
    </ErrorContent>
</ErrorBoundary>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override void OnInitialized() => Sidebar.OnChange += StateHasChanged;

    public void Dispose() => Sidebar.OnChange -= StateHasChanged;
}
